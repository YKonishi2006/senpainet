rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 運営メンバー判定：admins/{email} ドキュメントが存在すれば運営
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // 相談：公開読み取り／作成は誰でも（項目制限あり）／更新・削除は運営のみ
    match /consultations/{id} {
      allow read: if true;
      allow create: if request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 60
                    && request.resource.data.body is string
                    && request.resource.data.body.size() <= 4000;
      allow update, delete: if isAdmin();
    }

    // 回答：各相談のサブコレクション。公開読み取り／作成は誰でも（本文制限あり）／
    //       編集・削除は運営のみ（他人の回答を消せない）
    match /consultations/{cid}/answers/{aid} {
      allow read: if true;
      allow create: if request.resource.data.body is string
                    && request.resource.data.body.size() > 0
                    && request.resource.data.body.size() <= 4000;
      allow update, delete: if isAdmin();
    }

    // 返信：回答のサブコレクション。公開読み取り／作成は誰でも／編集・削除は運営のみ
    match /consultations/{cid}/answers/{aid}/replies/{rid} {
      allow read: if true;
      allow create: if request.resource.data.body is string
                    && request.resource.data.body.size() > 0
                    && request.resource.data.body.size() <= 2000;
      allow update, delete: if isAdmin();
    }

    // コレクショングループ検索（全相談の回答・返信を一括取得）を許可するために必要。
    // ※ Firestore ではサブコレクションのルールだけでは collectionGroup クエリは通らない
    match /{path=**}/answers/{aid} {
      allow read: if true;
    }
    match /{path=**}/replies/{rid} {
      allow read: if true;
    }

    // 通報：作成は誰でも／閲覧・対応・削除は運営のみ
    match /reports/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ログインユーザーのプロフィール：本人だけが読み書きできる（運営は閲覧可）
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isAdmin();

      // マイページ用の投稿履歴（本人のみ）。相談本体は匿名のままで uid を持たない。
      match /myPosts/{pid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // 先輩プロフィール（得意分野タグ＋通知先メール）
    // メールアドレスを含むため公開読み取りは禁止。作成は誰でも（自己登録）、
    // 閲覧・編集・削除は運営のみ。マッチングとメール送信はサーバー側(Functions)が行う。
    match /senpaiProfiles/{id} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 3
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.tags is list;
      allow read, update, delete: if isAdmin();
    }

    // 送信メール（Trigger Email 拡張がこのコレクションを監視して送信する）
    // 運営メンバーの招待メールなどをここに積む。作成・閲覧は運営のみ。
    match /mail/{id} {
      allow create, read, update, delete: if isAdmin();
    }

    // 公開設定（相談タグの一覧など）。表示に必要なので読み取りは全員、変更は運営のみ。
    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 通知キュー（タグ付き相談の通知依頼）。作成は誰でも、閲覧・処理は運営/サーバーのみ。
    match /mailQueue/{id} {
      allow create: if request.resource.data.consultationId is string
                    && request.resource.data.tags is list;
      allow read, update, delete: if isAdmin();
    }

    // 運営メンバー：自分の許可確認は本人、一覧の閲覧と追加・削除は運営のみ。
    // （管理コンソールの「運営メンバー」画面から招待・解除できる）
    match /admins/{email} {
      allow read: if request.auth != null
                  && (request.auth.token.email == email || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // それ以外は既定で拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
